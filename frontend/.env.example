# Vite dev server port for local development.
VITE_DEV_PORT=5173

# Local dev proxy target. In production, keep API calls relative if backend serves frontend.
VITE_API_PROXY_TARGET=http://localhost:4000

# Only set this when frontend and backend are hosted on different domains.
# Example: VITE_API_BASE_URL=https://api.your-domain.com
VITE_API_BASE_URL=
